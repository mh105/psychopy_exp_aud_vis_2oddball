        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="$&quot;INSTRUCTIONS: \n \n In this task you will see a series of shapes. \n \n There are three different shapes. Every time you see the following shape, a &quot;+ STIMULI[&quot;oddball&quot;][&quot;text&quot;]+ &quot;, respond by pressing the Green key.\n \nNow press any of the white keys to see the shape.&quot;" valType="str" updates="set every repeat" name="text"/>
