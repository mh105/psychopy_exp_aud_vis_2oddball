        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="$&quot;INSTRUCTIONS: Now we will see all the three shapes again.\n \nPay attention and decide which shape you need to respond to:\n \nis it the &quot; + STIMULI['oddball']['text'] + &quot;, the &quot; + STIMULI['regular']['text'] + &quot;, or the &quot; + STIMULI['distractor']['text'] + &quot;?\n \nPress any of the white keys to see the three shapes together.&quot;" valType="str" updates="set every repeat" name="text"/>
